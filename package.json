{
  "name": "alexleung.ca",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--use-system-ca\" next dev",
    "prepare": "git config core.hooksPath .githooks || true",
    "image:variants": "node scripts/generate-image-variants.mjs",
    "image:variants:stage": "node scripts/generate-image-variants.mjs --staged --stage-generated",
    "now:timeline:backfill": "node scripts/backfill-now-timeline.mjs",
    "now:timeline:check": "node scripts/check-now-timeline.mjs",
    "prebuild": "yarn image:variants",
    "build": "next build && yarn build:deploy-marker",
    "build:prod": "NEXT_PUBLIC_ENABLE_ANALYTICS=true yarn build",
    "build:deploy-marker": "node scripts/generate-deploy-marker.mjs",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "playwright:smoke:run": "playwright test --project=chromium-smoke --project=webkit-smoke --project=mobile-chromium-smoke --project=mobile-webkit-smoke",
    "playwright:visual:run": "playwright test --project=chromium-visual --project=mobile-chromium-visual",
    "playwright:visual:update:run": "playwright test --project=chromium-visual --project=mobile-chromium-visual --update-snapshots",
    "test:e2e:host": "bash -lc 'set -euo pipefail; corepack install; corepack yarn install --immutable; corepack yarn playwright install --with-deps; corepack yarn playwright:smoke:run'",
    "test:e2e:visual:host": "bash -lc 'set -euo pipefail; corepack install; corepack yarn install --immutable; corepack yarn playwright install --with-deps; corepack yarn playwright:visual:run'",
    "test:e2e:visual:update:host": "bash -lc 'set -euo pipefail; corepack install; corepack yarn install --immutable; corepack yarn playwright install --with-deps; corepack yarn playwright:visual:update:run'",
    "test:e2e": "docker compose run --rm -e PLAYWRIGHT_BASE_URL playwright-smoke",
    "test:e2e:visual": "docker compose run --rm -e PLAYWRIGHT_BASE_URL playwright-visual",
    "test:e2e:visual:update": "docker compose run --rm -e PLAYWRIGHT_BASE_URL playwright-update",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "perf:lighthouse": "lhci autorun --config=.lighthouserc.json",
    "lint": "eslint . && prettier --check '{src,docs,playwright,scripts,.github}/**/*.{js,jsx,ts,tsx,css,md,json,yml,mjs}' '*.{js,mjs,ts,json,md,yml}' && yarn lint:unused",
    "lint:unused": "knip --reporter compact",
    "lint:fix": "eslint --fix . && prettier --write '{src,docs,playwright,scripts,.github}/**/*.{js,jsx,ts,tsx,css,md,json,yml,mjs}' '*.{js,mjs,ts,json,md,yml}'",
    "predeploy": "yarn build:prod",
    "deploy": "gh-pages -d out"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.4",
    "decimal.js": "^10.6.0",
    "feed": "^5.2.1",
    "next": "^16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-icons": "^5.6.0",
    "react-schemaorg": "^2.0.1",
    "rehype-sanitize": "^6.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/hast": "^3.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "gh-pages": "^6.3.0",
    "gray-matter": "^4.0.3",
    "hast-util-sanitize": "^5.0.2",
    "http-server": "^14.1.1",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "katex": "^0.16.45",
    "knip": "^6.7.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "rehype-katex": "^7.0.1",
    "rehype-pretty-code": "^0.14.3",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-math": "^6.0.0",
    "remark-rehype": "^11.1.2",
    "schema-dts": "^2.0.0",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  },
  "resolutions": {
    "basic-ftp@npm:^5.0.2": "npm:5.3.0",
    "brace-expansion@npm:^2.0.2": "npm:2.0.3",
    "brace-expansion@npm:^5.0.2": "npm:5.0.5",
    "flatted@npm:^3.2.9": "npm:3.4.2",
    "glob@npm:^13.0.0": "npm:13.0.6",
    "minimatch@npm:^9.0.4": "npm:9.0.9",
    "minimatch@npm:^10.2.0": "npm:10.2.5",
    "path-to-regexp@npm:~0.1.12": "npm:0.1.13",
    "picomatch@npm:^4.0.2": "npm:4.0.4",
    "picomatch@npm:^4.0.3": "npm:4.0.4",
    "postcss@npm:8.4.31": "npm:8.5.10",
    "postcss@npm:^8.5.6": "npm:8.5.10",
    "tmp@npm:^0.1.0": "npm:0.2.5",
    "tar@npm:^7.5.4": "npm:7.5.11"
  },
  "packageManager": "yarn@4.13.0+sha512.5c20ba010c99815433e5c8453112165e673f1c7948d8d2b267f4b5e52097538658388ebc9f9580656d9b75c5cc996f990f611f99304a2197d4c56d21eea370e7"
}
